# Supabase — Werte aus dem Supabase Dashboard (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJxxxxx

# App URL — lokal: http://localhost:3000 | Produktion: https://deine-domain.de
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase Service Role Key — NUR serverseitig, NIE NEXT_PUBLIC_!
# Erforderlich für: job_summaries-Cache-Inserts, Konto-Löschung (Auth-Admin)
SUPABASE_SERVICE_ROLE_KEY=eyJxxxxx

# Google Gemini via Vertex AI — NUR serverseitig, NIE NEXT_PUBLIC_!
# Guthaben-Projekt: siehe Google Cloud Console. Service-Account braucht Rolle "Vertex AI User".
GOOGLE_CLOUD_PROJECT=dein-gcp-projekt-id
GOOGLE_CLOUD_LOCATION=europe-west4
# GCP_SERVICE_ACCOUNT_KEY_B64=<Service-Account-JSON als Base64-String>


# Upstash Redis — Rate-Limiting über alle Serverless-Instanzen hinweg.
# Kostenloser Tier reicht: https://console.upstash.com → Redis-DB anlegen.
# Ohne diese Werte greift lokal ein In-Memory-Fallback (pro Instanz).
UPSTASH_REDIS_REST_URL=https://xxxxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=xxxxx
